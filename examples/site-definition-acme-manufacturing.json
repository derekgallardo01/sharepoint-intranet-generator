    {
      "key": "faq",
      "type": "faq",
      "title": "Plant FAQ",
      "url": "/sites/intranet-faq",
      "summary": "The questions Production, Quality, and Supply Chain answer most often.",
      "questions": [
        { "q": "Where do I file an incident report?", "a": "Use the Incident report form on the Production page. Your shift supervisor is auto-notified." },
        { "q": "How do I open a non-conformance report (NCR)?", "a": "On the Quality page, open the Non-Conformance Reports library and use New. Set severity and owner before saving." },
        { "q": "Where is the approved supplier list?", "a": "On the Supply Chain page under quick links." },
        { "q": "Who approves an Engineering Change Notice (ECN)?", "a": "The Engineering lead for the affected line, plus Quality if the change touches a controlled drawing." }
      ]
    },
