        "owners": "Acme-Production-Owners",
        "members": "Acme-Production-Members",
        "visitors": "Acme-AllStaff",
        "inheritance": "broken"
      },
      "libraries": [
        {
          "name": "Standard Operating Procedures",
          "contentType": "Acme SOP",
          "retention": "Keep 10 years after Effective Date",
          "columns": [
            { "name": "Title", "type": "Text", "required": true },
            { "name": "Line", "type": "Choice", "required": true },
            { "name": "Owner", "type": "Person", "required": true },
            { "name": "Effective Date", "type": "Date", "required": true },
            { "name": "Review Date", "type": "Date", "required": false }
